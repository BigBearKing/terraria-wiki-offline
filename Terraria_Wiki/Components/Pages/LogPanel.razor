@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Terraria_Wiki.Services
@inject IJSRuntime JSRuntime
@implements IDisposable

<div id="log-panel" class="log-panel @(AppState.SidebarIsExpanded ? "expanded" : "collapsed")">
    <div class="drag-handle"></div>
    <div class="log-header">
        <div class="left-group">
            <span class="log-title">日志</span>
            <span class="log-info">@(AppState.ProcessingTaskId != 0 ? "当前任务：" + AppState.Tasks[AppState.ProcessingTaskId].Name : "")</span>
        </div>

        <div class="close-btn button" @onclick="CloseLogPanel">
            <Icon Name="dismiss" />
        </div>
    </div>
    <div id="log-container" class="log-container">
        <Virtualize @ref="_virtualize"
                    ItemsProvider="LoadLogs"
                    Context="log"
                    OverscanCount="20">
            <div class="log-line">@log</div>
        </Virtualize>
    </div>
</div>

@code {

    private Virtualize<string> _virtualize;

    private bool _isAutoScrolling = false; // 防止重入

    protected override void OnInitialized()
    {
        base.OnInitialized();
        AppState.OnChange += StateHasChanged;
        App.LogManager.OnLogAdded += RefreshLog;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {


            await Task.Delay(30);

            await JSRuntime.InvokeVoidAsync("scrollToBottomImmediate", "log-container");

            await JSRuntime.InvokeVoidAsync("setupResponsiveSwipe", "log-panel");


        }
    }

    private async ValueTask<ItemsProviderResult<string>> LoadLogs(ItemsProviderRequest req)
    {
        var total = App.LogManager.GetTotalCount();
        // 这里读取的永远是当前 _activeLogPath 的内容
        var items = await App.LogManager.GetLogsAsync(req.StartIndex, req.Count);
        return new ItemsProviderResult<string>(items, total);
    }

    private async void RefreshLog()
    {
        // 如果正在处理中，跳过
        if (_isAutoScrolling) return;
        _isAutoScrolling = true;

        await InvokeAsync(async () =>
        {
            // 1. 告诉 Virtualize 数据变了
            if (_virtualize != null)
            {
                await _virtualize.RefreshDataAsync();
            }
            StateHasChanged();

            await JSRuntime.InvokeVoidAsync("scrollToBottom", "log-container");
        });
        _isAutoScrolling = false;
    }

    [JSInvokable]
    public static void CloseLogPanel()
    {
        App.AppStateManager?.LogPanelIsOpen = false;
    }

    public void Dispose()
    {
        _ = JSRuntime.InvokeVoidAsync("swipeManagers.log-panel.dispose");
        App.LogManager.OnLogAdded -= RefreshLog;
        AppState.OnChange -= StateHasChanged;
    }
}

<style>
    .log-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        flex-shrink: 0;
    }



    .close-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 8px; /* 给一个好看的圆角 */
        color: var(--text-secondary); /* 默认用次要文字颜色，没那么突兀 */
        cursor: pointer;
    }

    body.has-hover .close-btn:hover {
        background-color: var(--hover-bg);
        color: var(--text-primary);
    }

    .log-panel.expanded {
        left: calc(var(--sidebar-width-expanded) + 8px);
        width: 40vw;
    }

    .log-panel.collapsed {
        left: calc(var(--sidebar-width-collapsed) + 8px);
        width: 50vw;
    }

    .log-panel {
        padding: 12px;
        gap: 12px;
        position: fixed;
        display: flex;
        flex-direction: column;
        bottom: 4px;
        transition: width 0.3s, left 0.3s;
        height: 50vh;
        background: var(--bg-color);
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        border-radius: 16px;
        z-index: 902;
    }

    .drag-handle {
        display: none;
    }

    .left-group {
        display: flex;
        gap: 12px;
        align-items: baseline;
    }

    .log-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        -webkit-user-select: none;
        user-select: none;
        min-width: 0;
    }

    .log-info {
        font-size: 0.9rem;
        color: var(--text-secondary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        -webkit-user-select: none;
        user-select: none;
        min-width: 0;
    }

    .log-container {
        width: 100%;
        height: 100%;
        background-color: var(--bg-color-secondary);
        border: 12px solid transparent;
        border-radius: 16px;
        overflow-y: auto;
        font-size: 0.8rem;
        overflow-anchor: none;
    }

    .log-line {
        color: var(--text-secondary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    @@media (max-width: 768px) {
        .log-panel.expanded,
        .log-panel.collapsed {
            /* 1. 宽度占满屏幕 */
            left: 0;
            right: 0;
            width: 100vw;
            /* 2. 位居页面最下方 */
            bottom: 0;
            /* 3. 高度为屏幕一半 */
            height: 50vh;
            /* 移动端视觉优化：底部不需要圆角，顶部保留圆角 */
            border-radius: 16px 16px 0 0;
            margin: 0;
            /* 如果有底栏 bottom-bar，可能需要考虑是否被完全覆盖 */
        }
        
        .close-btn {
            display: none;
        }

        .log-container {
            /* 移动端缩小内边距，增加显示面积 */
            border: 8px solid transparent;
        }

        .drag-handle {
            display: block;
            width: 40px;
            height: 5px;
            background: #ccc;
            border-radius: 3px;
            position: fixed;
            align-self: anchor-center;
        }
        /* 动画类：用于松手后的平滑过渡 */
        .smooth-return {
            transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }
    }
</style>