@page "/data/{WikiId:int}"
@using Terraria_Wiki.Components.Icons
@using Terraria_Wiki.Models
@using Terraria_Wiki.Services
@inject NavigationManager NavManager
<div class="page-anim page-content">
    <div class="header-with-back">
        <div class="icon-btn button" @onclick="BackToList">
            <Icon Name="arrow-left" Size="24" />
        </div>
        <span class="page-title">@_selectedWiki?.Title</span>
    </div>
    <div class="list-container detail-container">
        @if (_selectedWiki != null)
        {

            @* --- 状态 A：已下载 (显示数据大小、更新按钮、页面列表) --- *@
            <div class="title-placeholder">
                <div class="placeholder-icon">
                    <img src="images/@_selectedWiki.Title.Replace(" ", "_")/logo.png" style="
                    height: 85px;object-fit: contain;" />
                </div>
                <h3>@(_selectedWiki.IsPageDownloaded? _selectedWiki.Title: "尚未获取数据")</h3>
                <p>@(_selectedWiki.IsPageDownloaded? _selectedWiki.Description: "你需要下载基础数据包和资源文件才能离线浏览此 Wiki")</p>
            </div>
            @if (_selectedWiki.IsPageDownloaded)
            {
                @* 1. 数据概览卡片 *@
                <div class="stats-panel">
                    <div class="stat-item">
                        <span class="stat-label">数据库大小</span>
                        <span class="stat-value">@FileHelper.GetSizeString(_selectedWiki.DataSize)</span>
                    </div>

                    <div class="stat-item">
                        <span class="stat-label">页面数量</span>
                        <span class="stat-value">@_selectedWiki.PageCount</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">重定向数量</span>
                        <span class="stat-value">@_selectedWiki.RedirectCount</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">资源数量</span>
                        <span class="stat-value">@_selectedWiki.ResourceCount</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">上次更新时间</span>
                        <span class="stat-value">@_selectedWiki.UpdateTime.ToString("yyyy-MM-dd\nHH:mm")</span>
                    </div>
                </div>

                @* 2. 操作按钮 *@
                <div class="action-row">
                    <div class="primary-btn btn-blue" @onclick="() => RunSafe(UpdateData)">
                        <Icon Name="sync" Size="16" />
                        @(AppState.ProcessingTaskId == 4 ? AppState.Tasks[4].ProcessingText : "检查数据更新")
                    </div>

                    <div class="primary-btn btn-green" @onclick="() => RunSafe(CleanUpRes)">
                        <Icon Name="clean" Size="16" />
                        @(AppState.ProcessingTaskId == 5 ? AppState.Tasks[5].ProcessingText : "清理未用资源")
                    </div>
                    @if (_selectedWiki.IsResourceDownloaded)
                    {
                        <div class="primary-btn btn-red" @onclick="() => RunSafe(DeleteRes)">
                            <Icon Name="delete" Size="16" />
                            @(AppState.ProcessingTaskId == 6 ? AppState.Tasks[6].ProcessingText : "删除资源数据")
                            
                        </div>
                    }
                    else
                    {
                        <div class="primary-btn btn-blue" @onclick="() => RunSafe(DownloadRes)">
                            <Icon Name="download" Size="16" />
                            @(AppState.ProcessingTaskId == 3 ? AppState.Tasks[3].ProcessingText : "下载资源数据")
                            
                        </div>
                    }


                    <div class="primary-btn btn-red" @onclick="() => RunSafe(DeleteDatabase)">
                        <Icon Name="delete" Size="16" />
                        @(AppState.ProcessingTaskId == 8 ? AppState.Tasks[8].ProcessingText : "删除数据库")
                        
                    </div>
                </div>

            }
            else
            {
                <div class="download-actions">

                    <div class="download-card">
                        <div class="dl-info">
                            <div class="dl-title">所有内容</div>
                            <div class="dl-desc">包含所有文本内容、属性和链接关系、图片、音视频</div>
                        </div>
                        <div class="primary-btn btn-blue" @onclick="() => RunSafe(DownloadAll)">
                            @(AppState.ProcessingTaskId == 2 ? AppState.Tasks[2].ProcessingText : "下载")
                        </div>
                    </div>
                    <div class="download-card">
                        <div class="dl-info">
                            <div class="dl-title">基础数据</div>
                            <div class="dl-desc">仅包含所有文本内容、属性和链接关系</div>
                        </div>
                        <div class="primary-btn btn-blue" @onclick="() => RunSafe(DownloadPages)">
                            @(AppState.ProcessingTaskId == 2 ? AppState.Tasks[2].ProcessingText : "下载")
                            
                        </div>
                    </div>
                </div>
            }

        }

    </div>
</div>
@code {
    [Parameter]
    public int WikiId { get; set; }

    protected override void OnInitialized()
    {
        AppState.OnChange += RefreshUI;
    }

    public void Dispose()
    {
        AppState.OnChange -= RefreshUI;
    }

    private void RefreshUI()
    {
        InvokeAsync(StateHasChanged);
    }

    private void BackToList()
    {
        AppState.CurrentPage = "data";
        NavManager.NavigateTo(AppState.CurrentPage);
    }
    private WikiBook _selectedWiki;
    protected override async Task OnInitializedAsync()
    {
        base.OnInitializedAsync();
        _selectedWiki = await App.ManagerDb.GetItemAsync<WikiBook>(WikiId);

        CheckFailList();


    }


    private async Task RunSafe(Func<Task> action)
    {
        // 统一检查
        if (AppState.ProcessingTaskId != 0)
        {
            AppState.TriggerAlert("提示", "请稍后，正在处理任务");
            return;
        }
        await action();
    }

    private async Task CheckFailList()
    {
        if (App.DataManager.CheckFailList())
        {
            bool result = await Application.Current.Windows[0].Page.DisplayAlertAsync("提示", "检测到有失败文件，是否要重试下载？", "是", "否");
            if (result)
            {
                _ = App.DataManager.RetryFailList();
            }
        }

    }

    private async Task DownloadAll()
    {

        _ = App.DataManager.DownloadDataAsync(true);

    }
	
    private async Task DownloadPages()
    {

        _ = App.DataManager.DownloadDataAsync(false);

    }

    private async Task DownloadRes()
    {

        _ = App.DataManager.DownloadResAsync();

    }

    private async Task UpdateData()
    {
        bool isAll = _selectedWiki.IsResourceDownloaded;

        _ = App.DataManager.UpdateDataAsync(isAll);

    }

    private async Task CleanUpRes()
    {
        _ = App.DataManager.CleanUpResAsync();

    }

    private async Task DeleteRes()
    {
        bool isConfirmed = await Application.Current.Windows[0].Page?.DisplayAlertAsync("提示", "确认删除图片资源等数据吗？", "确定", "取消");
        if (isConfirmed)
        {
            _ = App.DataManager.DeleteResAsync();
            BackToList();
            

        }
    }

    private async Task DeleteDatabase()
    {
        bool isConfirmed = await Application.Current.Windows[0].Page?.DisplayAlertAsync("提示", "确认删除整个数据库（包含收藏、历史）吗？", "确定", "取消");
        if (isConfirmed)
        {
            await App.DataManager.DeleteDatabase();
            BackToList();
        }
    }

}

<style>

    .icon-btn {
        padding: 4px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .header-with-back {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: large;
        font-weight: 500;
    }

    /* === 详情页样式 === */
    .detail-container {
        display: flex;
        flex-direction: column;
        padding: 0 0 20px;
        gap: 16px;
    }

    /* 统计面板 */
    .stats-panel {
        background-color: var(--bg-color-secondary);
        border-radius: 16px;
        padding: 20px;
        /* 改用允许换行的 Flex 布局 */
        display: flex;
        flex-wrap: wrap;
        gap: 16px; /* 添加元素之间的间距 */
        align-items: stretch;
    }

    .stat-item {
        /* 核心：基础宽度设定为 120px，但允许它们自由放大（flex-grow: 1）或缩小 */
        flex: 1 1 120px;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
    }

    .stat-label {
        font-size: 0.8rem;
        color: var(--text-secondary);
        margin-bottom: 4px;
        text-align: center;
    }

    .stat-value {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-primary);
        white-space: pre-line;
        text-align: center;
    }

    .action-row {
        display: grid;
        /* 默认状态（大屏）：一行 4 个，均分宽度 */
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
    }

    /* 当屏幕宽度小于特定值时触发 */
    @@media (max-width: 768px) {
        .action-row {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    /* 可选：如果屏幕极窄，强制变成单列 */
    @@media (max-width: 365px) {
        .action-row {
            grid-template-columns: 1fr;
        }
    }

    /* 通用按钮 */
    /* 1. 基础按钮样式重置 */
    .primary-btn {
        /* 移除之前的 background-color 和 color */
        padding: 12px;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        gap: 8px;
        /* 关键：添加平滑过渡 */
        transition: all 0.2s;
        border: none;
        /* 防止移动端点击出现高亮背景块 */
        -webkit-tap-highlight-color: transparent;
        -webkit-user-select: none;
        user-select: none;
    }

    /* 2. 交互反馈 (通用) */
    body.has-hover .primary-btn:hover {
        /* 悬停时：整体提亮 20% */
        /* 在深色背景下，brightness > 1 会让半透明色块显得更“实”、更亮 */
        filter: brightness(1.2);
    }
    

    .primary-btn:active {
        /* 点击时：稍微变暗并缩小，产生“按压感” */
        filter: brightness(1.0); /* 恢复亮度或稍微暗一点 */
        transform: scale(0.97); /* 物理回弹效果 */
    }

    /* === 颜色变体 (Tinted Style) === */

    /* 蓝色 */
    .btn-blue {
        background-color: var(--blue-tertiary);
        color: var(--blue-primary);
    }

    /* 绿色 */
    .btn-green {
        background-color: var(--green-tertiary);
        color: var(--green-primary);
    }

    /* 红色 */
    .btn-red {
        background-color: var(--red-tertiary);
        color: var(--red-primary);
    }

    .title-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 30px 20px;
        text-align: center;
    }

    .placeholder-icon {
        font-size: 4rem;
        margin-bottom: 16px;
    }

    .title-placeholder h3 {
        margin: 0 0 8px 0;
        color: var(--text-primary);
    }

    .title-placeholder p {
        margin: 0;
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    .download-actions {
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding-bottom: 24px;
    }

    .download-card {
        background-color: var(--bg-color-secondary);
        border-radius: 16px;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .dl-title {
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 4px;
    }

    .dl-desc {
        font-size: 0.8rem;
        color: var(--text-secondary);
        line-height: 1.4;
    }

</style>