@page "/data"
@inject NavigationManager NavManager
@using Terraria_Wiki
@using Terraria_Wiki.Components.Icons
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Terraria_Wiki.Services
@using Terraria_Wiki.Models

<div class="page-anim page-content">

	<header class="page-header">
		<span class="page-title">@Loc.Get("DataManagement.Title")</span>
	</header>

	<div class="list-container wiki-card-list">
		@* === 视图 1：Wiki 列表选择 === *@

		@if (_wikiBookList != null)
		{
			@foreach (var wiki in _wikiBookList)
			{
				<div class="manage-card button @(wiki.Id == AppState.ActiveWikiBookId ? "active-card" : "")" @onclick="() => OnCardClicked(wiki)">
					<div class="manage-card-icon">
						<img src="images/@wiki.DataFolder/logo.png" style="width: 48px;
						height: 48px;object-fit: contain;" />
					</div>
					<div class="manage-card-info">
						<div class="manage-card-title">@wiki.Title</div>
						<div class="manage-card-desc">@wiki.Description</div>
						<div class="manage-card-status @(wiki.IsPageDownloaded ? "status-ok" : "status-none")">
							@(wiki.IsPageDownloaded ? Loc.Get("DataManagement.Installed") : Loc.Get("DataManagement.NotInstalled"))
						</div>
					</div>
					<Icon Name="arrow-left" Size="20" style="transform: rotate(180deg); color: var(--text-secondary);" />
				</div>
			}
		}

	</div>
</div>

@code {


	private List<WikiBook> _wikiBookList;


	protected override void OnInitialized()
	{
		AppState.OnChange += RefreshUI;
		Loc.OnChange += RefreshUI;
	}

	public void Dispose()
	{
		AppState.OnChange -= RefreshUI;
		Loc.OnChange -= RefreshUI;
	}

	private void RefreshUI() => InvokeAsync(StateHasChanged);

	protected override async Task OnInitializedAsync()
	{
		_wikiBookList = await App.ManagerDb.GetItemsAsync<WikiBook>();
	}

	private async Task OnCardClicked(WikiBook item)
	{
		if (item.Id == AppState.ActiveWikiBookId)
		{
			// 当前已选择的 Wiki → 直接进入详情
			AppState.CurrentPage = "data/" + item.Id;
			NavManager.NavigateTo(AppState.CurrentPage);
			return;
		}

		// 非当前 Wiki → 弹窗确认切换
		bool confirm = await Application.Current!.Windows[0].Page!.DisplayAlertAsync(
			Loc.Get("DataManagement.SwitchWikiTitle"),
			Loc.Get("DataManagement.SwitchWikiDesc", item.Title),
			Loc.Get("Common.OK"),
			Loc.Get("Common.Cancel"));

		if (confirm)
		{
			Preferences.Default.Set("ActiveWikiBookId", item.Id);
			AppService.RestartApp();
		}
	}





}

<style>

	.wiki-card-list{
		gap:12px;
		padding: 12px 0 max(12px, var(--safe-area-bottom));
	}
	/* 布局微调 */





	.manage-card {
		background-color: var(--bg-color-secondary);
		border-radius: 16px;
		padding: 16px;
		display: flex;
		align-items: center;
	}

	.manage-card-icon {
		width: 48px;
		height: 48px;
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.5rem;
		font-weight: bold;
		margin-right: 16px;
	}

	.manage-card-info {
		flex: 1;
	}

	.manage-card-title {
		font-weight: 600;
		font-size: 1.05rem;
		color: var(--text-primary);
		margin-bottom: 4px;
	}

	.manage-card-desc {
		font-size: 0.85rem;
		color: var(--text-secondary);
		margin-bottom: 6px;
		display: -webkit-box;
		-webkit-line-clamp: 1;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.manage-card-status {
		font-size: 0.75rem;
		display: inline-block;
		padding: 2px 8px;
		border-radius: 99px;
		font-weight: 500;
	}

	.status-ok {
		background-color: var(--green-tertiary);
		color: var(--green-primary);
	}

	.status-none {
		background-color: var(--bg-color);
		color: var(--text-secondary);
	}

	.active-card{
		background-color: var(--blue-tertiary);
	}
</style>